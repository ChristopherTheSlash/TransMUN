rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function chair() {
      return request.auth.token.email == "chair@transmun.invalid";
    }

    function validRoomItem() {
      return request.resource.data.senderAccount is string
        && request.resource.data.senderAccount.size() <= 50
        && request.resource.data.senderName is string
        && request.resource.data.senderName.size() <= 50
        && request.resource.data.senderRole in ["Delegate", "Chair"];
    }

    match /rooms/{roomId}/messages/{messageId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && validRoomItem()
        && request.resource.data.type == "message"
        && request.resource.data.status in ["pending", "approved"]
        && request.resource.data.to is string
        && request.resource.data.to.size() <= 80
        && request.resource.data.recipientAccounts is list
        && request.resource.data.recipientAccounts.size() >= 1
        && request.resource.data.recipientAccounts.size() <= 3
        && request.resource.data.recipientLabels is list
        && request.resource.data.recipientLabels.size() >= 1
        && request.resource.data.recipientLabels.size() <= 3
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 1600
        && request.resource.data.chairNote is string
        && request.resource.data.chairNote.size() <= 600;
      allow update: if chair()
        && request.resource.data.status in ["approved", "returned"]
        && request.resource.data.chairNote is string
        && request.resource.data.chairNote.size() <= 600;
      allow delete: if false;
    }

    match /rooms/{roomId}/documents/{documentId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.type == "document"
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 90
        && request.resource.data.url is string
        && request.resource.data.url.size() <= 500
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 2000;
      allow update, delete: if false;
    }

    match /rooms/{roomId}/accounts/{accountId} {
      allow read: if signedIn();
      allow create: if chair()
        && request.resource.data.account is string
        && request.resource.data.account.size() <= 50
        && request.resource.data.authEmail is string
        && request.resource.data.authEmail.size() <= 120
        && request.resource.data.label is string
        && request.resource.data.label.size() <= 50
        && request.resource.data.role in ["delegate", "chair"];
      allow update, delete: if chair();
    }
  }
}
